# Groq API key for the FRIDAY chatbot.
# Used SERVER-SIDE ONLY (api/chat.js) — it is never bundled into the browser.
# Get a free key at https://console.groq.com/keys
GROQ_API_KEY=your_groq_key_here

# Local dev only — set to "true" if `npm run dev` fails with
# UNABLE_TO_VERIFY_LEAF_SIGNATURE (TLS interception on your network/AV).
# Never set this in production / Vercel.
GROQ_DEV_INSECURE_TLS=false
